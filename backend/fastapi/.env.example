# ===========================================
# AutoAdmin FastAPI Backend Environment Configuration
# ===========================================
# Copy this file to .env and fill in your actual values

# ===========================================
# APPLICATION SETTINGS
# ===========================================
APP_NAME=AutoAdmin API
VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ===========================================
# SECURITY SETTINGS
# ===========================================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALLOWED_HOSTS=["http://localhost:3000", "http://127.0.0.1:3000"]

# ===========================================
# REQUIRED API KEYS AND CONFIGURATIONS
# ===========================================

# OpenAI Configuration (REQUIRED)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# Firebase Configuration (REQUIRED)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/autoadmin
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ===========================================
# CELERY CONFIGURATION (Background Tasks)
# ===========================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json

# ===========================================
# AI/LLM SERVICE CONFIGURATION
# ===========================================

# LangSmith Configuration (Optional - for tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=autoadmin-backend

# ===========================================
# EXTERNAL SERVICE INTEGRATION
# ===========================================

# GitHub Configuration (Optional - for DevOps operations)
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_REPO=your-username/your-repo

# Tavily Search API (Optional - for market research)
TAVILY_API_KEY=tvly-your-tavily-api-key

# HubSpot API (Optional - for CRM integration)
HUBSPOT_API_KEY=your-hubspot-private-app-token
HUBSPOT_API_VERSION=v3

# Stripe API (Optional - for payment processing)
STRIPE_API_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ===========================================
# AGENT CONFIGURATION
# ===========================================
MAX_CONCURRENT_AGENTS=5
AGENT_TIMEOUT=300
MAX_RETRIES=3

# ===========================================
# FILE HANDLING CONFIGURATION
# ===========================================
MAX_FILE_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=["text/plain", "application/pdf", "application/json", "text/csv", "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "image/jpeg", "image/png", "image/gif"]

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=autoadmin.log

# ===========================================
# RATE LIMITING CONFIGURATION
# ===========================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ===========================================
# MONITORING CONFIGURATION
# ===========================================
ENABLE_METRICS=true
METRICS_PORT=9090

# ===========================================
# WEBHOOK CONFIGURATION
# ===========================================
WEBHOOK_SECRET=your-webhook-secret-key
WEBHOOK_TIMEOUT=30

# ===========================================
# CORS CONFIGURATION
# ===========================================
CORS_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]

# ===========================================
# DEVELOPMENT SETTINGS
# ===========================================
# Enable auto-reload for development
AUTO_RELOAD=true

# Enable debug endpoints
ENABLE_DEBUG_ENDPOINTS=true

# Mock external services for development
MOCK_EXTERNAL_SERVICES=true

# ===========================================
# PRODUCTION SETTINGS
# ===========================================
# Set to true in production
PRODUCTION=false

# SSL configuration (for production)
SSL_CERT_PATH=/etc/ssl/certs/cert.pem
SSL_KEY_PATH=/etc/ssl/private/key.pem

# Performance settings
WORKER_CONNECTIONS=1000
KEEPALIVE_TIMEOUT=65

# ===========================================
# DEPLOYMENT SPECIFIC CONFIGURATION
# ===========================================

# For Render
RENDER_EXTERNAL_URL=https://your-app.onrender.com
RENDER_EXTERNAL_PORT=10000

# For Railway
RAILWAY_ENVIRONMENT=production
RAILWAY_STATIC_URL=https://your-app.railway.app

# For AWS
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-s3-bucket
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# ===========================================
# FEATURE FLAGS
# ===========================================
ENABLE_WEBSOCKETS=true
ENABLE_FILE_UPLOADS=true
ENABLE_VECTOR_SEARCH=true
ENABLE_BACKGROUND_TASKS=true
ENABLE_METRICS_COLLECTION=true
ENABLE_HEALTH_CHECKS=true
ENABLE_CACHING=true