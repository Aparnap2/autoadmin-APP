# ===========================================
# REQUIRED: Core Service Configuration
# ===========================================

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Firebase Configuration
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# ===========================================
# OPTIONAL: External Service Integration
# ===========================================

# GitHub Configuration (for DevOps operations)
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_REPO=your-username/your-repo

# Tavily Search API Configuration (for market research)
TAVILY_API_KEY=tvly-your-tavily-api-key

# ===========================================
# OPTIONAL: System Configuration
# ===========================================

# Logging Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Environment (development, staging, production)
ENVIRONMENT=development

# Session ID (auto-generated if not provided)
SESSION_ID=

# Agent Configuration
MAX_RETRIES=3
AGENT_TIMEOUT=300
CONCURRENT_AGENTS=5

# LangSmith Configuration (Optional, for tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=autoadmin-backend

# ===========================================
# OPTIONAL: Docker Configuration
# ===========================================

# Docker Hub credentials (for pushing images)
DOCKER_USERNAME=your-docker-username
DOCKER_PASSWORD=your-docker-password

# ===========================================
# OPTIONAL: Security Configuration
# ===========================================

SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ===========================================
# OPTIONAL: Database Configuration (if using external DB)
# ===========================================

DATABASE_URL=postgresql://user:password@localhost:5432/autoadmin