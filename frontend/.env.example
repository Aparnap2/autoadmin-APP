# Firebase Configuration (Database, Storage only - no Auth, no Functions)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# GitHub Configuration (Required for agent triggers)
GITHUB_TOKEN=ghp_your-github-token
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=your-repository-name

# Netlify Functions URL (replaces Firebase Functions)
EXPO_PUBLIC_NETLIFY_FUNCTIONS_URL=https://your-app.netlify.app
NETLIFY_API_URL=https://your-app.netlify.app

# FastAPI Backend Configuration
FASTAPI_BASE_URL=http://localhost:8000

# OpenAI API for vector embeddings and AI operations
OPENAI_API_KEY=sk-your-openai-api-key

# Webhook Configuration (Optional but recommended)
WEBHOOK_SECRET=your-webhook-secret-for-signature-verification

# LLM Provider Configuration (New System)
# Primary LLM Provider
LLM_PROVIDER=openai                    # Options: openai, anthropic, groq, custom
LLM_API_KEY=your_llm_api_key          # Your primary LLM API key
LLM_BASE_URL=                         # Optional: Custom endpoint URL
LLM_MODEL=gpt-3.5-turbo               # Model name for the provider
LLM_TEMPERATURE=0.7                   # Temperature (0.0 - 2.0)
LLM_MAX_TOKENS=2048                   # Maximum tokens per response
LLM_TIMEOUT=60000                     # Request timeout in milliseconds

# Provider Fallback Configuration
LLM_ENABLE_FALLBACK=false              # Enable provider fallbacks
LLM_FALLBACK_PROVIDERS=anthropic,groq # Comma-separated fallback providers
LLM_MAX_RETRIES=3                     # Maximum retry attempts
LLM_RETRY_ERRORS=rate_limit,server_error,timeout # Errors to retry on

# Load Balancing (Advanced)
LLM_ENABLE_LOAD_BALANCING=false        # Enable load balancing
LLM_LOAD_BALANCING_STRATEGY=round-robin # Strategy: round-robin, random, least-used

# Caching Configuration
LLM_ENABLE_CACHE=true                  # Enable response caching
LLM_CACHE_TTL=300                     # Cache TTL in seconds
LLM_CACHE_MAX_SIZE=1000               # Maximum cache entries

# Monitoring and Metrics
LLM_ENABLE_MONITORING=true             # Enable provider monitoring
LLM_TRACK_METRICS=true                # Track performance metrics
LLM_TRACK_COSTS=false                 # Track API costs
LLM_ALERT_FAILURES=true               # Alert on provider failures

# Legacy AI/LLM Configuration (Deprecated - will be removed in v2.0)
# EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key
# GROQ_API_KEY=gsk_your-groq-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# External Services Configuration
TAVILY_API_KEY=tvly-your-tavily-api-key
HUBSPOT_API_KEY=your-hubspot-api-key
HUBSPOT_PRIVATE_APP_TOKEN=your-hubspot-private-app-token

# Development Configuration
NODE_ENV=development
LOG_LEVEL=debug

# Production Configuration (uncomment for production)
# NODE_ENV=production
# LOG_LEVEL=info
# EXPO_PUBLIC_API_URL=https://your-api.domain.com

# Monitoring and Analytics
SENTRY_DSN=your-sentry-dsn
GOOGLE_ANALYTICS_ID=GA-XXXXXXXX-X

# Feature Flags
EXPO_PUBLIC_ENABLE_ANALYTICS=true
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=true
EXPO_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true

# Rate Limiting
API_RATE_LIMIT_REQUESTS=100
API_RATE_LIMIT_WINDOW_MS=3600000

# Cache Configuration
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE_MB=100

# Security Configuration
CORS_ORIGIN=https://your-domain.com
MAX_REQUEST_SIZE_MB=10
SESSION_SECRET=your-session-secret

# Custom Business Configuration
BUSINESS_HOURS_START=09:00
BUSINESS_HOURS_END=17:00
BUSINESS_TIMEZONE=America/New_York
BUSINESS_CURRENCY=USD